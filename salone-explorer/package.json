{
  "name": "salone-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Salone Explorer - Sierra Leone tour-guide SPA (FambulTik / TpGroup).",
  "scripts": {
    "dev": "vite",
    "generate:reviews-snapshot": "tsx scripts/generate-reviews-snapshot.ts",
    "build": "npm run generate:reviews-snapshot && tsc --noEmit && vite build && tsx scripts/generate-sitemap.ts",
    "build:prerender": "npm run build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && tsx scripts/prerender.ts",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "build:email-copy": "tsx scripts/build-email-copy.ts",
    "check:email-copy": "tsx scripts/build-email-copy.ts && git diff --exit-code -- supabase/functions/_shared/email-copy.json",
    "migrate:attractions": "tsx scripts/migrate-attractions-to-supabase.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@supabase/supabase-js": "^2.47.10",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
