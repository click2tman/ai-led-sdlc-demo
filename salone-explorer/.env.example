# Salone Explorer environment variables (SPEC §16).
# Copy to .env.local for local dev. Only VITE_-prefixed vars reach the
# browser bundle; never put a service-role key or any server secret here.

# Canonical site URL - production custom domain. Drives canonical URLs,
# sitemap.xml, OG/Twitter tags, and llms.txt. Vercel preview deploys use
# their generated *.vercel.app URL.
VITE_SITE_URL=https://slint-ai-led-sdlc.tpgroupsl.com

# Data source toggle: "file" (Phase 1 default) or "supabase" (Phase 2.5)
VITE_ATTRACTIONS_SOURCE=file

# Phase 5 - Supabase project: slint-ai-led-sdlc-demo
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Phase 2.5 migration only (server-side script). The service-role key
# bypasses RLS, so it lives ONLY in your shell when running
# `npm run migrate:attractions` - never commit it, never VITE_-prefix it.
SUPABASE_SERVICE_ROLE_KEY=
